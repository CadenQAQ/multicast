#!/usr/bin/env python3
import socket
import struct
import sys
import time
import string

# === 参数解析 ===
# 用法示例：
#   python mctest.py 224.0.130.165:30024
#   python mctest.py 224.0.130.165:30024 6.201.10.67

if len(sys.argv) < 2:
    print("用法: python mctest.py 224.0.130.165:30024 [本地网卡IP(可选)]")
    sys.exit(1)

addr_port = sys.argv[1]
try:
    MCAST_GRP, MCAST_PORT = addr_port.split(":")
    MCAST_PORT = int(MCAST_PORT)
except ValueError:
    print("参数格式错误，应为 224.0.130.165:30024")
    sys.exit(1)

# 可选：指定本地接口 IP
IFACE_IP = sys.argv[2] if len(sys.argv) > 2 else "0.0.0.0"

print(f"组播地址: {MCAST_GRP}")
print(f"组播端口: {MCAST_PORT}")
print(f"本地网卡: {IFACE_IP if IFACE_IP != '0.0.0.0' else '自动选择'}")

# === 创建 UDP socket ===
sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM, socket.IPPROTO_UDP)
sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)

try:
    sock.bind((MCAST_GRP, MCAST_PORT))
except OSError:
    sock.bind(("", MCAST_PORT))

# === 加入组播 ===
if IFACE_IP == "0.0.0.0":
    # 使用系统默认接口
    mreq = struct.pack(
        "4sl",
        socket.inet_aton(MCAST_GRP),
        socket.INADDR_ANY
    )
else:
    # 指定接口 IP
    mreq = socket.inet_aton(MCAST_GRP) + socket.inet_aton(IFACE_IP)

sock.setsockopt(socket.IPPROTO_IP, socket.IP_ADD_MEMBERSHIP, mreq)

# 设置超时（用于检测是否掉流）
sock.settimeout(3.0)

print(f"\n✔ 已加入组播 {MCAST_GRP}:{MCAST_PORT}，开始接收数据...\n")

# === 工具函数 ===
def is_text_data(data: bytes) -> bool:
    """判断数据是否为可打印文本"""
    try:
        text = data.decode("utf-8")
        printable_ratio = sum(c in string.printable for c in text) / max(len(text), 1)
        return printable_ratio > 0.8
    except UnicodeDecodeError:
        return False

# === 接收循环 ===
while True:
    try:
        data, addr = sock.recvfrom(2048)
        timestamp = time.strftime("%Y-%m-%d %H:%M:%S", time.localtime())

        if is_text_data(data):
            text = data.decode(errors="ignore").strip()
            print(f"[{timestamp}] 来自 {addr} 的文本数据: {text}")
        else:
            hex_data = " ".join(f"{b:02x}" for b in data)
            print(
                f"[{timestamp}] 来自 {addr} 的二进制数据 "
                f"({len(data)} 字节): {hex_data}"
            )

    except socket.timeout:
        timestamp = time.strftime("%Y-%m-%d %H:%M:%S", time.localtime())
        print(f"[{timestamp}] （没有收到数据）")
